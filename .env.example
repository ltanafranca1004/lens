# Lens environment configuration.
# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string used by the backend and Alembic.
# Format: postgresql://USER[:PASSWORD]@HOST[:PORT]/DBNAME
DATABASE_URL=postgresql://user@localhost/lens

# Secret used to sign and verify JWT auth tokens (HS256).
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=

# Groq API key, used when USE_MOCK_LLM=false.
# Create one at https://console.groq.com/keys
GROQ_API_KEY=

# When true, the LLM layer returns canned mock responses (no API calls).
# Set to false to call the real Gemini API.
USE_MOCK_LLM=true
